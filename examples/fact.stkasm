.def fact: args=1, locals=0
;	if n < 2 return 1
	load 0 ; n
	iconst 2
	ilt
	jmpf cont
	iconst 1
	ret
cont:
;	return n * fact(n-1)
	load 0 ; n
	load 0
	iconst 1
	isub  ; n - 1
	call fact()
	imul ; n * fact(n-1)
	ret

.def main: args=0, locals=0
; print fact(5)
    sconst "Factorial de 5: "
    print
	iconst 5
	call fact()
	print
	halt
